{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/jobs", "destination": "/jobs.html" },
    { "source": "/training", "destination": "/training.html" },
    { "source": "/timeclock", "destination": "/timecard.html" }
  ]
}
